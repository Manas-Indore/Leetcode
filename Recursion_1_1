import java.util.*;

class Solution {

    Set<List<Integer>> set = new HashSet<>();

    private void getAllCombinations(int[] arr, int idx, int target,
                                    List<List<Integer>> ans,
                                    List<Integer> comb) {

        if (idx == arr.length || target < 0) {
            return;
        }

        if (target == 0) {
            if (!set.contains(comb)) {
                ans.add(new ArrayList<>(comb));
                set.add(new ArrayList<>(comb));
            }
            return;
        }

        // Include current element

        comb.add(arr[idx]);

        // Single use
        // getAllCombinations(arr, idx + 1, target - arr[idx], ans, comb);

        // Multiple use
        getAllCombinations(arr, idx, target - arr[idx], ans, comb);

        comb.remove(comb.size() - 1);

        // Exclude current element
        getAllCombinations(arr, idx + 1, target, ans, comb);
    }

    public List<List<Integer>> combinationSum(int[] candidates, int target) {

        List<List<Integer>> ans = new ArrayList<>();
        List<Integer> comb = new ArrayList<>();

        getAllCombinations(candidates, 0, target, ans, comb);

        return ans;
    }
}
